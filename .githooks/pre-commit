#!/bin/sh
# Pre-commit hook: auto-build documentation from source code.
# Syncs source code, injects verification status, regenerates sidebar.

REPO_ROOT="$(git rev-parse --show-toplevel)"

STAGED=$(git diff --cached --name-only --diff-filter=ACM)

NEEDS_BUILD=false
for f in $STAGED; do
    case "$f" in
        *.hpp|*.test.cpp|docs/*.md) NEEDS_BUILD=true ;;
    esac
done

if [ "$NEEDS_BUILD" = true ]; then
    python3 "$REPO_ROOT/scripts/build_site.py"
    git diff --name-only -- docs/ _includes/ | xargs -r git add
fi
